generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  logo          String?
  plan          PlanType  @default(BASIC)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  planExpiresAt DateTime?
  trialEndsAt   DateTime?
  users         User[]
}

model User {
  id            String         @id @default(cuid())
  name          String
  designation   String?
  email         String?        @unique
  phone         String
  password      String?
  slug          String         @unique
  country       String
  countryCode   String
  employeeCode  String         @unique
  role          UserRole       @default(EMPLOYEE)
  orgId         String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  labels        Json           @default("[]")
  profileImage  String?
  archived      Boolean        @default(false)
  cardImageUrl  String?
  tokenVersion  Int            @default(0)
  cardViews     CardView[]
  leads         Lead[]
  loginSessions LoginSession[]
  scans         ScanLog[]
  organization  Organization   @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model LoginSession {
  id        String   @id @default(cuid())
  userId    String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CardView {
  id         String   @id @default(cuid())
  employeeId String
  isUnique   Boolean  @default(true)
  createdAt  DateTime @default(now())
  employee   User     @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model ScanLog {
  id         String   @id @default(cuid())
  employeeId String
  createdAt  DateTime @default(now())
  employee   User     @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model Lead {
  id           String   @id @default(cuid())
  name         String
  phoneNumber  String
  countryCode  String
  scannedEmpId String
  createdAt    DateTime @default(now())
  scannedEmp   User     @relation(fields: [scannedEmpId], references: [id])

  @@index([scannedEmpId])
}

model SuperAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model OtpToken {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  otp             String
  verified        Boolean   @default(false)
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  attempts        Int       @default(0)
  lockedUntil     DateTime?
  sendCount       Int       @default(0)
  sendWindowStart DateTime?
}

enum PlanType {
  BASIC
  PRO
}

enum UserRole {
  ADMIN
  EMPLOYEE
}
